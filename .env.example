# ── Dataloom v3.0 — Environment Variables ─────────────────────────────────────
# Copy these into Railway → Project → Variables
# Never commit the real values to GitHub.

# ── Database (Railway fills these automatically if using Railway Postgres) ──────
# DATABASE_URL is auto-injected by Railway. If using external DB, set manually:
# DB_TYPE=postgresql
# DB_HOST=your-host
# DB_PORT=5432
# DB_NAME=olist_demo
# DB_USER=postgres
# DB_PASSWORD=your-password

# ── Model provider ─────────────────────────────────────────────────────────────
# Option A — OpenAI (recommended for production)
MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Option B — Ollama (local only, not suitable for Railway)
# MODEL_PROVIDER=ollama
# OLLAMA_MODEL=deepseek-v3.1:671b-cloud

# ── Flask ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=replace-with-random-64-char-hex

# ── Demo mode — locks down /api/setup/connect for public deployments ───────────
DEMO_MODE=true

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT=20
